generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String    @id @default(uuid())
  nome      String
  email     String    @unique
  senha     String?
  role      Role      @default(FORMANDO)
  createdAt DateTime  @default(now())
  accounts  Account[]
  formador  Formador?
  formando  Formando?
  sessions  Session[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Formador {
  id                String              @id @default(uuid())
  especialidade     String?
  competencias      String?
  linkedin          String?
  github            String?
  idioma            String?
  nacionalidade     String?
  userId            String              @unique
  user              User                @relation(fields: [userId], references: [id])

  aulas             Aula[]
  avaliacoes        Avaliacao[]
  convites          Convite[]
  documentos        Documento[]
  DocumentoFormador DocumentoFormador[]
  modulosLecionados FormadorModulo[]
  presencas         Presenca[]
}

model Formando {
  id         String      @id @default(uuid())
  userId     String      @unique
  avaliacoes Avaliacao[]
  documentos Documento[]
  user       User        @relation(fields: [userId], references: [id])
  inscricoes Inscricao[]
  presencas  Presenca[]
}

model Curso {
  id           String      @id @default(uuid())
  nome         String
  descricao    String?
  status       StatusCurso @default(ATIVO)
  createdAt    DateTime    @default(now())
  cargaHoraria Int         @default(0)
  dataFim      DateTime?
  dataInicio   DateTime?
  inscricoes   Inscricao[]
  modulos      Modulo[]
}

model Modulo {
  id           String           @id @default(uuid())
  nome         String
  descricao    String?
  ordem        Int
  cursoId      String
  cargaHoraria Int              @default(0)
  aulas        Aula[]
  avaliacoes   Avaliacao[]
  formadores   FormadorModulo[]
  curso        Curso            @relation(fields: [cursoId], references: [id])
}

model FormadorModulo {
  formadorId String
  moduloId   String
  formador   Formador @relation(fields: [formadorId], references: [id])
  modulo     Modulo   @relation(fields: [moduloId], references: [id])

  @@id([formadorId, moduloId])
}

model Inscricao {
  id         String   @id @default(uuid())
  formandoId String
  cursoId    String
  dataInicio DateTime @default(now())
  curso      Curso    @relation(fields: [cursoId], references: [id])
  formando   Formando @relation(fields: [formandoId], references: [id])

  @@unique([formandoId, cursoId])
}

model Aula {
  id         String     @id @default(uuid())
  titulo     String
  dataHora   DateTime
  duracao    Int
  moduloId   String
  formadorId String
  formador   Formador   @relation(fields: [formadorId], references: [id])
  modulo     Modulo     @relation(fields: [moduloId], references: [id])
  presencas  Presenca[]
}

model Presenca {
  id            String         @id @default(uuid())
  status        StatusPresenca @default(AUSENTE)
  justificativa String?
  aulaId        String
  formandoId    String
  formadorId    String
  aula          Aula           @relation(fields: [aulaId], references: [id])
  formador      Formador       @relation(fields: [formadorId], references: [id])
  formando      Formando       @relation(fields: [formandoId], references: [id])

  @@unique([aulaId, formandoId])
}

model Avaliacao {
  id         String   @id @default(uuid())
  descricao  String?
  nota       Float
  moduloId   String
  formandoId String
  formadorId String
  createdAt  DateTime @default(now())
  formador   Formador @relation(fields: [formadorId], references: [id])
  formando   Formando @relation(fields: [formandoId], references: [id])
  modulo     Modulo   @relation(fields: [moduloId], references: [id])
}

model Documento {
  id            String          @id @default(uuid())
  tipo          String
  numero        String
  dataEmissao   DateTime
  dataExpiracao DateTime?
  status        StatusDocumento @default(VALIDO)
  formandoId    String
  formando      Formando        @relation(fields: [formandoId], references: [id])
  formadorId    String?
  formador      Formador?       @relation(fields: [formadorId], references: [id])
  createdAt     DateTime        @default(now())
}

model Convite {
  id           String        @id
  formadorId   String
  cursoId      String?
  moduloId     String?
  status       StatusConvite @default(PENDENTE)
  descricao    String?
  dataEnvio    DateTime      @default(now())
  dataResposta DateTime?
  createdAt    DateTime      @default(now())
  Formador     Formador      @relation(fields: [formadorId], references: [id], onDelete: Cascade)
}

model DocumentoFormador {
  id            String          @id
  tipo          String
  numero        String?
  dataEmissao   DateTime?
  dataExpiracao DateTime?
  status        StatusDocumento @default(EM_FALTA)
  formadorId    String
  createdAt     DateTime        @default(now())
  Formador      Formador        @relation(fields: [formadorId], references: [id])
}

enum Role {
  COORDENADOR
  FORMADOR
  FORMANDO
}

enum StatusCurso {
  ATIVO
  PAUSADO
  ENCERRADO
}

enum StatusPresenca {
  PRESENTE
  AUSENTE
  JUSTIFICADO
}

enum StatusDocumento {
  VALIDO
  EXPIRADO
  A_EXPIRAR
  EM_FALTA
}

enum StatusConvite {
  PENDENTE
  ACEITE
  RECUSADO
}