generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String    @id @default(uuid())
  nome      String
  email     String    @unique
  senha     String?
  image     String?
  role      Role      @default(FORMANDO)
  createdAt DateTime  @default(now())
  accounts  Account[]
  formador  Formador?
  formando  Formando?
  sessions  Session[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Formador {
  id            String  @id @default(uuid())
  especialidade String?
  competencias  String?
  linkedin      String?
  github        String?
  idioma        String?
  nacionalidade String?
  userId        String  @unique
  user          User    @relation(fields: [userId], references: [id])

  aulas              Aula[]
  avaliacoes         Avaliacao[]
  convites           Convite[]
  documentos         Documento[]
  DocumentoFormador  DocumentoFormador[]
  modulosLecionados  FormadorModulo[]
  presencas          Presenca[]
  /// Novos: Templates de avaliação definidos por este formador
  templatesAvaliacao TemplateAvaliacao[]
  /// Disponibilidades do formador
  disponibilidades   Disponibilidade[]
}

/// Disponibilidade: Horários em que o formador está disponível
/// Estrutura: dia da semana + hora:minuto (30 em 30 min)
model Disponibilidade {
  id         String   @id @default(uuid())
  formadorId String
  diaSemana  String /// "Segunda", "Terça", "Quarta", "Quinta", "Sexta"
  hora       Int /// 9-17
  minuto     Int /// 0 ou 30
  disponivel Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  formador Formador @relation(fields: [formadorId], references: [id], onDelete: Cascade)

  /// Garantir apenas um slot por (formadorId, diaSemana, hora, minuto)
  @@unique([formadorId, diaSemana, hora, minuto])
}

model Formando {
  id         String              @id @default(uuid())
  userId     String              @unique
  avaliacoes Avaliacao[]
  documentos Documento[]
  user       User                @relation(fields: [userId], references: [id])
  inscricoes Inscricao[]
  presencas  Presenca[]
  submissoes SubmissaoTrabalho[]
  reviews    ReviewModulo[]
  convites   Convite[]
}

model Curso {
  id           String      @id @default(uuid())
  nome         String
  descricao    String?
  status       StatusCurso @default(ATIVO)
  createdAt    DateTime    @default(now())
  cargaHoraria Int         @default(0)
  dataFim      DateTime?
  dataInicio   DateTime?
  inscricoes   Inscricao[]
  modulos      Modulo[]
  convites     Convite[]
}

model Modulo {
  id                 String              @id @default(uuid())
  nome               String
  descricao          String?
  ordem              Int
  cursoId            String
  cargaHoraria       Int                 @default(0)
  aulas              Aula[]
  avaliacoes         Avaliacao[]
  formadores         FormadorModulo[]
  /// Novos: Templates de avaliação para este módulo
  templatesAvaliacao TemplateAvaliacao[]
  curso              Curso               @relation(fields: [cursoId], references: [id])
  reviews            ReviewModulo[]
  convites           Convite[]
}

model FormadorModulo {
  formadorId String
  moduloId   String
  formador   Formador @relation(fields: [formadorId], references: [id])
  modulo     Modulo   @relation(fields: [moduloId], references: [id])

  @@id([formadorId, moduloId])
}

model Inscricao {
  id         String   @id @default(uuid())
  formandoId String
  cursoId    String
  dataInicio DateTime @default(now())
  curso      Curso    @relation(fields: [cursoId], references: [id])
  formando   Formando @relation(fields: [formandoId], references: [id])

  @@unique([formandoId, cursoId])
}

model Aula {
  id         String     @id @default(uuid())
  titulo     String
  dataHora   DateTime
  duracao    Int
  moduloId   String
  formadorId String
  formador   Formador   @relation(fields: [formadorId], references: [id])
  modulo     Modulo     @relation(fields: [moduloId], references: [id])
  presencas  Presenca[]
}

model Presenca {
  id                 String         @id @default(uuid())
  status             StatusPresenca @default(AUSENTE)
  justificativa      String?
  comentarioFormando String?
  documentoUrl       String?
  aulaId             String
  formandoId         String
  formadorId         String
  aula               Aula           @relation(fields: [aulaId], references: [id])
  formador           Formador       @relation(fields: [formadorId], references: [id])
  formando           Formando       @relation(fields: [formandoId], references: [id])

  @@unique([aulaId, formandoId])
}

model Avaliacao {
  id         String   @id @default(uuid())
  descricao  String?
  nota       Float
  moduloId   String
  formandoId String
  formadorId String
  createdAt  DateTime @default(now())
  formador   Formador @relation(fields: [formadorId], references: [id])
  formando   Formando @relation(fields: [formandoId], references: [id])
  modulo     Modulo   @relation(fields: [moduloId], references: [id])
}

model Documento {
  id            String          @id @default(uuid())
  tipo          String
  numero        String
  dataEmissao   DateTime
  dataExpiracao DateTime?
  status        StatusDocumento @default(VALIDO)
  formandoId    String
  formando      Formando        @relation(fields: [formandoId], references: [id])
  formadorId    String?
  formador      Formador?       @relation(fields: [formadorId], references: [id])
  fileUrl       String?
  createdAt     DateTime        @default(now())
}

model Convite {
  id           String        @id @default(uuid())
  formadorId   String?
  formandoId   String?
  cursoId      String?
  moduloId     String?
  status       StatusConvite @default(PENDENTE)
  descricao    String?
  dataEnvio    DateTime      @default(now())
  dataResposta DateTime?
  createdAt    DateTime      @default(now())
  Formador     Formador?     @relation(fields: [formadorId], references: [id], onDelete: Cascade)
  Formando     Formando?     @relation(fields: [formandoId], references: [id], onDelete: Cascade)
  Curso        Curso?        @relation(fields: [cursoId], references: [id])
  Modulo       Modulo?       @relation(fields: [moduloId], references: [id])
}

model DocumentoFormador {
  id            String          @id
  tipo          String
  numero        String?
  dataEmissao   DateTime?
  dataExpiracao DateTime?
  status        StatusDocumento @default(EM_FALTA)
  formadorId    String
  createdAt     DateTime        @default(now())
  fileUrl       String?
  Formador      Formador        @relation(fields: [formadorId], references: [id])
}

/// ============================================================================
/// MODELOS DE AVALIAÇÕES COM TEMPLATES (Implementação do Sistema de Notas)
/// ============================================================================
/// 
/// Sistema de avaliação flexível onde cada formador define templates de
/// avaliação por módulo. Cada template contém um conjunto de componentes
/// de avaliação (ex: Ficha, Projeto, Teste) com pesos específicos que somam
/// a 80% da nota final. Os restantes 20% vêm da assiduidade.
///
/// Fluxo:
/// 1. Formador define TemplateAvaliacao com ItemTemplateAvaliacao(s)
/// 2. Sistema calcula NotaParcial(is) para cada componente de cada aluno
/// 3. NotaFinal = (Assiduidade × 0.20) + (MédiaComponentes × 0.80)
/// ============================================================================

/// TemplateAvaliacao: Define o template de avaliação para um (formador, módulo)
/// Um formador pode ter um template diferente para cada módulo que leciona

model TemplateAvaliacao {
  id         String   @id @default(uuid())
  formadorId String
  moduloId   String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  /// Relações
  formador      Formador                @relation(fields: [formadorId], references: [id], onDelete: Cascade)
  modulo        Modulo                  @relation(fields: [moduloId], references: [id], onDelete: Cascade)
  items         ItemTemplateAvaliacao[]
  notasParciais NotaParcial[]

  /// Constraint: Um formador só pode ter um template por módulo
  @@unique([formadorId, moduloId])
}

/// ItemTemplateAvaliacao: Item individual de um template (ex: Ficha, Projeto)
/// O peso deve representar a percentagem da avaliação (máx 80%)

model ItemTemplateAvaliacao {
  id               String    @id @default(uuid())
  templateId       String
  nome             String /// Nome do componente: "Ficha", "Projeto", "Teste", etc
  descricao        String? /// Instruções ou descrição do trabalho
  peso             Float /// Peso em percentagem (máx 80%) - ex: 20.0 para 20%
  ordem            Int       @default(1) /// Ordem de exibição na tabela
  dataLimite       DateTime?
  ficheiroAnexoUrl String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  /// Relações
  template      TemplateAvaliacao   @relation(fields: [templateId], references: [id], onDelete: Cascade)
  notasParciais NotaParcial[]
  submissoes    SubmissaoTrabalho[]

  @@index([templateId])
}

/// SubmissaoTrabalho: Submissão de um trabalho por um aluno
model SubmissaoTrabalho {
  id          String   @id @default(uuid())
  itemId      String
  formandoId  String
  ficheiroUrl String /// URL ou nome do arquivo entregue
  dataEntrega DateTime @default(now())
  comentario  String? /// Comentário do aluno na entrega

  /// Relações
  item     ItemTemplateAvaliacao @relation(fields: [itemId], references: [id], onDelete: Cascade)
  formando Formando              @relation(fields: [formandoId], references: [id], onDelete: Cascade)

  @@unique([itemId, formandoId])
  @@index([formandoId])
}

/// NotaParcial: Nota parcial de um aluno em um componente específico
/// Armazena a nota (0-20) que o formador atribui em cada componente

model NotaParcial {
  id         String   @id @default(uuid())
  valor      Float /// Nota entre 0 e 20
  formandoId String
  itemId     String
  templateId String /// Para queries rápidas
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  /// Relações
  item     ItemTemplateAvaliacao @relation(fields: [itemId], references: [id], onDelete: Cascade)
  template TemplateAvaliacao     @relation(fields: [templateId], references: [id], onDelete: Cascade)

  /// Constraint: Uma nota parcial única por (aluno, item)
  @@unique([formandoId, itemId])
  @@index([templateId, formandoId])
}

model ReviewModulo {
  id         String   @id @default(uuid())
  nota       Int /// Nota de 1 a 5
  comentario String?  @db.Text
  formandoId String
  moduloId   String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  formando Formando @relation(fields: [formandoId], references: [id], onDelete: Cascade)
  modulo   Modulo   @relation(fields: [moduloId], references: [id], onDelete: Cascade)

  @@unique([formandoId, moduloId])
}

enum Role {
  COORDENADOR
  FORMADOR
  FORMANDO
}

enum StatusCurso {
  ATIVO
  PAUSADO
  ENCERRADO
}

enum StatusPresenca {
  PRESENTE
  AUSENTE
  PENDENTE
  JUSTIFICADO
}

enum StatusDocumento {
  VALIDO
  EXPIRADO
  A_EXPIRAR
  EM_FALTA
}

enum StatusConvite {
  PENDENTE
  ACEITE
  RECUSADO
}
